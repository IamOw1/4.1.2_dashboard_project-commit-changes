# Фронтенд (Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/telemetry

# Режим
DEMO_MODE=true
SIMULATION_MODE=true
SIMULATOR_TYPE=grid
ALLOW_DEMO_COMMANDS=true

# Модели агентов (локальные пути опциональны)
CORE_AGENT_MODEL_PATH=data/models/core_agent/your_model.gguf
SUB_AGENT_MODEL_PATH=data/models/sub_agent/your_model.gguf
AGENT_MODEL_FORMAT=gguf
AGENT_QUANTIZATION=Q4_K_M

# DeepSeek API — подставьте свой ключ (не коммитьте реальный ключ в git)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL_NAME=deepseek-chat

# Дрон / RC
DRONE_TYPE=dji_mavic_2_mini
RC_SOURCE=mock
RC_DEVICE=0
DRONE_CONNECTION_STRING=udp:127.0.0.1:14550

# Сервер
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Безопасность
COBA_API_KEY=
DASHBOARD_PASSWORD=admin

# БД
DATABASE_PATH=data/memory/knowledge_base.db

# Логи
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
