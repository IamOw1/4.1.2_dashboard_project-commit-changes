# 🌐 Фронтенд
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/telemetry

# 🎮 Режим запуска
DEMO_MODE=true                    # true = заглушки, false = реальный дрон
ALLOW_DEMO_COMMANDS=true          # Разрешить команды в демо-режиме

# 🤖 Модели агентов
CORE_AGENT_MODEL_PATH=data/models/core_agent/llama-3-8b.Q4_K_M.gguf
SUB_AGENT_MODEL_PATH=data/models/sub_agent/qwen2.5-7b.Q5_K_S.gguf
AGENT_MODEL_FORMAT=gguf           # gguf | onnx | pytorch
AGENT_QUANTIZATION=Q4_K_M         # для GGUF: Q4_K_M | Q5_K_S | Q8_0

# 🌐 DeepSeek API (fallback если локальная модель не найдена)
DEEPSEEK_API_KEY=sk-27743e75aab840aeb6c14f4dd0e0f4f6  # Приоритет: локальная модель → DeepSeek API

# 🔌 Подключение к дрону
DRONE_TYPE=dji_mavic_2_mini       # dji_mavic_2_mini | mavlink_generic | simulator
CONNECTION_TYPE=usb               # usb | wifi | serial
DRONE_IP=192.168.1.100            # для wifi-подключения

# 🌐 Сервер
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
ENABLE_CORS=true

# 🔐 Безопасность
API_KEY=your_api_key_here         # для продакшена!
JWT_SECRET=change_me_in_prod

# 📊 Логирование
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FILE=data/logs/app.log
ENABLE_TELEMETRY_LOGGING=true

# 🧪 Тестирование
ENABLE_E2E_TESTS=true
TEST_DRONE_SIMULATOR=airsim       # airsim | grid | simnet | skyrover | unreal
